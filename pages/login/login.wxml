<view class="login-container">
  <view class="login-header">
    <view class="logo">🏓</view>
    <text class="title">乒乓搭子</text>
    <text class="subtitle">选择用户进入 Demo 模式</text>
  </view>

  <view class="user-list">
    <view class="user-card" wx:for="{{users}}" wx:key="id" bindtap="handleLogin" data-user-id="{{item.id}}">
      <view class="user-avatar" style="background: {{item.color}};">
        <text class="avatar-text">{{item.initials}}</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{item.name}}</text>
        <text class="user-detail">🏓 Lv.{{item.level}} · {{item.district}}</text>
        <text class="user-detail">{{item.bio}}</text>
      </view>
      <view class="user-arrow">›</view>
    </view>
  </view>

  <view class="demo-badge">
    <text class="badge-text">Demo 模式 · 数据仅供开发测试</text>
  </view>
</view>
