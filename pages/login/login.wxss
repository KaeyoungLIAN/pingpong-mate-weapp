.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 80rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 150rpx;
  height: 150rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.55);
}

.user-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  flex: 1;
  justify-content: center;
  padding: 0 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  border: 2rpx solid rgba(255,255,255,0.08);
  transition: all 0.2s;
}

.user-card:active {
  background: rgba(255,255,255,0.18);
  transform: scale(0.98);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.user-detail {
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
}

.user-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.3);
  margin-left: 16rpx;
}

.demo-badge {
  margin-top: auto;
  padding: 20rpx 0;
}

.badge-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}
