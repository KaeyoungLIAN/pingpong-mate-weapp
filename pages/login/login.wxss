.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 120rpx 60rpx 80rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 40rpx;
  margin-bottom: 40rpx;
  background: rgba(255,255,255,0.1);
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.65);
  text-align: center;
  line-height: 1.5;
}

.login-btn-area {
  width: 100%;
  margin-top: auto;
  padding-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  border-radius: 48rpx;
}

.login-footer {
  margin-top: 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}
