.page {
  padding: 30rpx;
}

.detail-header {
  margin-bottom: 30rpx;
}

.creator-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eee;
}

.creator-info {
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
}

.wechat-row {
  display: flex;
  align-items: center;
  background: #f0f7ff;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.wechat-label {
  font-size: 26rpx;
  color: #666;
}

.wechat-value {
  font-size: 28rpx;
  color: #1677ff;
  font-weight: 500;
}

.copy-hint {
  font-size: 22rpx;
  color: #1677ff;
  margin-left: auto;
}

.detail-body {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.info-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f8f8f8;
}

.info-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #888;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

.applicant-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #eee;
}

.applicant-name {
  flex: 1;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-pending { background: #fff3cd; color: #856404; }
.status-accepted { background: #d4edda; color: #155724; }
.status-rejected { background: #f8d7da; color: #721c24; }
.status-cancelled { background: #e2e3e5; color: #383d41; }

.action-bar {
  padding: 30rpx;
}

.status-bar {
  text-align: center;
  padding: 40rpx;
}

.status-text {
  font-size: 28rpx;
  color: #999;
}
