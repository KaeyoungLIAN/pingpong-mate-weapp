.page {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 36rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #555;
  margin-bottom: 12rpx;
  display: block;
}

.picker {
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.picker.placeholder {
  color: #bbb;
}

.textarea {
  height: 120rpx;
}

.char-count {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: -10rpx;
}

.btn-area {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-skip {
  background: transparent;
  color: #999;
  border: none;
  font-size: 26rpx;
  text-align: center;
}
